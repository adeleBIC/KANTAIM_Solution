@page "/ShipmentPge/{id:int}/{number:int}"
@using KANTAIM.DAL.Model;
@using MudBlazor
@using static MudBlazor.Icons
@using Microsoft.AspNetCore.Components.Routing

<style>
    .main-container {
        padding: 10px;
        font-family: 'Roboto', sans-serif;
    }

    .selection-container, .display-container {
        background-color: #FFFFFF;
        border-radius: 10px;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
        padding: 20px;
        margin-bottom: 20px;
    }

    .title {
        color: #333333;
        text-align: center;
        margin-bottom: 20px;
    }

    .redtitle {
        color: red;
        text-align: center;
        margin-bottom: 20px;
    }

    .status-display, .status-item {
        color: #555555;
        margin: 10px 0;
        padding: 10px;
        background-color: #f2f2f2;
        border-radius: 10px;
    }

    .button-group {
        display: flex;
        justify-content: space-evenly;
    }

    .fillstatus-container {
        text-align: center;
    }


    .bouton {
        margin: 10px;
    }

</style>
@if(correct)
{
@*     @if (shipment)
        {
            <h3 class="title">Bien Sortie</h3>
        }
        else
        { *@

        <div class="display-container">
            <h3 class="title">Sortie de Rack</h3>

                <div class="status-display">
                    <div class="status-item">Produit: @Product.Name</div>
                @if (ColorOfProduct != null)
                {
                <div class="status-item">
                    Couleur: @ColorOfProduct.Name
                    <MudIcon Icon="@Icons.Material.Filled.Circle" Style="@($"color:{ColorOfProduct.ColorNumber};")" />
                    </div>
                
                }

            @if (CellStock != null)
            {
                <div class="status-item">Cellule: @CellStock.Name</div>
            }

            <div class="status-item">@ContainerScanner.ContainerType.Name: @ContainerScanner?.Number</div>
                </div>

                <div class="button-group">
            <MudButton Class="bouton"  Color="Color.Secondary" Variant="MudBlazor.Variant.Filled" Href="@($"/StockagePge/1/{ContainerScanner.Number}")" Match="NavLinkMatch.All">Déplacement Contenaire</MudButton>
            @if (!IsPalette)
            {
                @if (!ContainerScanner.ContainerType.IsContainable)
                {
                    <MudButton Class="bouton" Color="Color.Success" Variant="MudBlazor.Variant.Filled" OnClick="Shipment">Sortie</MudButton>
                }
                <MudButton Class="bouton" Color="Color.Info" Variant="MudBlazor.Variant.Filled" Href="@($"/InjectPge/1/{ContainerScanner.Number}")" Match="NavLinkMatch.All">Mise en Machine</MudButton>
            }
            </div>
        </div>
@*         } *@
}



