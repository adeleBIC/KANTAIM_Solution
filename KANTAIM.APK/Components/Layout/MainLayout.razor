@inherits LayoutComponentBase

@* <script src="js/managKeyboard.js"></script> *@
<script src="js/noFocus.js"></script>

<PageTitle>KANTAIM.APK</PageTitle>
<style>
    .bottom-tabs {
        width: 100%;
        display: flex;
        justify-content: space-around;
        padding: 0 20px;
    }
/* 
    .logintag {
        margin-right: 10px;
        font-size: 15px;
        position: absolute;
        top: 10px;
        right: 10px; 
    } */
</style>

@* Required *@
<MudThemeProvider Theme="BicTheme" />
<MudPopoverProvider />

@* Needed for dialogs *@
<MudDialogProvider/>

@* Needed for snackbars *@
<MudSnackbarProvider/>

<div class="page">
    <MudLayout>
        <MudAppBar Bottom="true" Fixed="true" Elevation="0" DisableGutters="true">
            <div class="bottom-tabs">
                <MudButton Color="Color.Inherit"
                           TabIndex="-1"
                           Class="nofocus"
                           Style="--mud-typography-button-size:25px;--mud-typography-button-weight : bold;"
                           Href="/"
                           Match="NavLinkMatch.Prefix">
                    Page principale
                </MudButton>
            </div>

        </MudAppBar>

        <MudMainContent style="margin-top: -20px;">
            @Body
        </MudMainContent>
    </MudLayout>
</div>

