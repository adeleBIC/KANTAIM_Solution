@page "/MenuPge"
@layout PhoneLayout
@using KANTAIM.DAL.Model;
@using KANTAIM.WEB.ViewModels;
@using MudBlazor
@using static MudBlazor.Icons

<style>
    .button-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 20px;
        gap: 10px; /* Adjusts spacing between buttons */
        width: 80%; /* Adjusts the width of the container to center it */
        margin: auto; /* Centers the container horizontally */
    }

    .MudButton {
        background: linear-gradient(145deg, #ff8a00, #e67600);
        border: 2px solid #fff;
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        border-radius: 12px;
        margin: 10px 0;
        padding: 15px 20px;
        font-size: 16px;
        font-weight: bold;
        color: white;
        text-align: center;
        width: 100%; /* Makes all buttons fill the container */
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .MudButton:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(0,0,0,0.3);
        }

</style>

<div class="button-container" >
    <MudButton Variant="MudBlazor.Variant.Filled" Color="Color.Primary" Href="/InitializtionPge/0/0">
        
        
        Machine</MudButton>
    <MudButton Variant="MudBlazor.Variant.Filled" Color="Color.Primary" Href="/StockagePge/0/0">Mise en Rack</MudButton>
    <MudButton Variant="MudBlazor.Variant.Filled" Color="Color.Primary" Href="/ShipmentPge/0/0">Sortie de Rack</MudButton>
    <MudButton Variant="MudBlazor.Variant.Filled" Color="Color.Primary" Href="/InjectPge/0/0">Mise en Machine</MudButton>
    <MudButton Variant="MudBlazor.Variant.Filled" Color="Color.Primary" Href="/StockagePge/0/0">Déplacement Contenaire</MudButton>
    <MudButton Variant="MudBlazor.Variant.Filled" Color="Color.Primary" Href="/TransferPge">Mise en Contenaire</MudButton>
</div>

