@page "/Administration/ProfilPge"
@using KANTAIM.DAL.Model;
@using KANTAIM.WEB.ViewModels;

<div class="pageTitle">
    <MudText Typo="Typo.h4">Profils</MudText>
</div>

@if (Profils != null)
{
    <MudDataGrid T="ProfilVM" RowClassFunc="RowClassFct" Items="@Profils" Dense=true Hover=true ReadOnly=false EditMode="MudBlazor.DataGridEditMode.Cell"
                 Virtualize="true" SelectOnRowClick=false MultiSelection=true SelectedItemsChanged="SelectionChanged" Bordered=true
                 Filterable="true" SortMode="SortMode.Multiple" Hideable="false" QuickFilter="@_quickFilter">
        <ToolBarContent>
            <MudIconButton Class="editButton" Variant="MudBlazor.Variant.Filled" Icon="@Icons.Material.Filled.Add" OnClick="AddAsync" Color="Color.Primary"></MudIconButton>
            <MudIconButton Class="editButton" Variant="MudBlazor.Variant.Filled" Icon="@Icons.Material.Filled.Save" OnClick="SaveAsync" Color="Color.Primary"></MudIconButton>
            <MudIconButton Class="editButton" Variant="MudBlazor.Variant.Filled" Icon="@Icons.Material.Filled.Delete" OnClick="DeleteAsync" Color="Color.Error"></MudIconButton>
            <MudIconButton Class="editButton" Variant="MudBlazor.Variant.Filled" Icon="@Icons.Material.Filled.Cancel" OnClick="CancelAsync" Color="Color.Primary"></MudIconButton>
            <MudSpacer />
            <MudTextField @bind-Value="_searchString" Placeholder="Recherche profils" Adornment="Adornment.Start" Immediate="true"
                          AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
        </ToolBarContent>
        <Columns>
            <SelectColumn ShowInFooter=false />
            <PropertyColumn Property="x => x.Name" Title="Nom" />
            <PropertyColumn Property="x => x.SelectedRackNames" Title="Racks">
                <EditTemplate>
                    <MudSelect T="string"
                               SelectedValues="context.Item.SelectedRackNames"
                               SelectedValuesChanged="@(new Func<IEnumerable<string>, Task>(v => OnSelectedRacksChanged(context.Item, v)))"
                               MultiSelection="true"
                               MultiSelectionTextFunc="@(new Func<List<string>, string>(GetMultiSelectionRackText))"
                               Variant="MudBlazor.Variant.Outlined"
                               Style="margin-bottom:5px;margin-top:5px">
                        @if (Racks != null)
                        {
                            @foreach (var f in Racks.Where(p => p.Active))
                            {
                                <MudSelectItem T="string" Value="@f.Name">@f.Name</MudSelectItem>
                            }
                        }
                    </MudSelect>
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Active" Title="Actif">
                <EditTemplate>
                    <MudCheckBox @bind-Checked=context.Item.Active />
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Comment" Title="Commentaire" Required=false />
        </Columns>
        <PagerContent>
            <MudDataGridPager T="ShapeVM" PageSizeOptions="@(new int[] {13, 30, 50,100})" />
        </PagerContent>
    </MudDataGrid>
}
else
{
    <MudCard>
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" />
        <MudCardContent>
            <MudSkeleton Width="30%" Height="42px;" />
            <MudSkeleton Width="80%" />
            <MudSkeleton Width="100%" />
        </MudCardContent>
        <MudCardActions>
            <MudSkeleton Width="64px" Height="40px" Class="ml-2" />
            <MudSkeleton Width="105px" Height="40px" Class="ml-3" />
        </MudCardActions>
        <MudProgressLinear Color="Color.Default" Indeterminate="true" Class="my-7" />
    </MudCard>
}