@page "/Administration/ColorProductPge"
@using KANTAIM.DAL.Model;
@using KANTAIM.WEB.Components.ProductfamilyComp
@using KANTAIM.WEB.ViewModels;
<style>

    .bordered-paper {
        border: 1px solid #dee2e6; /* Border color */
        border-radius: 4px; /* Rounded corners */
        overflow: hidden; /* Prevent overflow */
        /* margin: 20px; */ /* Space around the paper */
    }

    .tree-view-container {
        min-height: 500px; /* Minimum height for the tree view */
        padding: 10px; /* Padding inside the tree view */
        margin-bottom: 60px; /* Add margin to the bottom to prevent overlap with action buttons */
    }

    .tree-title {
        padding: 10px; /* Padding around title */
        background: #f5f5f5; /* Light grey background for the title */
        border-bottom: 1px solid #dee2e6; /* Border under the title */
    }

    .action-buttons {
        position: fixed;
        bottom: 0;
        width: 100%;
        background: white;
        padding: 10px;
        box-shadow: 0 -2px 5px rgba(0, 0, 0, 0.1);
    }

    .action-buttons .mud-grid-item {
        display: flex;
        justify-content: center; /* Center button horizontally */
        align-items: center; /* Center button vertically */
    }

    .sticky-header {
        position: sticky;
        top: 0;
        background: white;
        z-index: 1000;
    }

</style>

<div class="pageTitle sticky-header">
    <MudText Typo="Typo.h4">Couleurs & Produits</MudText>
</div>

<MudPaper Class="pa-4 sticky-header">
    <MudStack>
        <MudButton Color="Color.Secondary" Variant="MudBlazor.Variant.Filled" OnClick="OnExpandCollapseClick">@(Editer ? "Consultation" : "Edition")</MudButton>
    </MudStack>
</MudPaper>


@if (Editer)
{
    <MudGrid>


        <MudItem xs="6" Class="bordered-paper">
            <div class="tree-title sticky-header">
                <MudText Typo="Typo.h5">Couleurs</MudText>
            </div>
            <div class="tree-view-container">
                @if (Colors != null)
                {
                    <MudTreeView Items="ColorTreeItems" MultiSelection="true" Hover="true" @bind-SelectedValues="ColorSelectedValues">
                        <ItemTemplate>
                            @*  <MudTreeViewItem SelectedChanged="@(()=>SelectAsync(context,0))" Selected="@context.IsSelected" ActivatedChanged="@(()=>ActiveAsync(context,0))" @bind-Expanded="@context.IsExpanded" Items="@context.TreeItems" Value="@context" Text="@context.Name"></MudTreeViewItem> *@
                            <MudTreeViewItem @bind-Expanded="@context.IsExpanded" Items="@context.TreeItems" Value="@context" Text="@context.Name"></MudTreeViewItem>
                        </ItemTemplate>
                    </MudTreeView>
                }
            </div>
        </MudItem>
        <MudItem xs="6" Class="bordered-paper">
            <div class="tree-title sticky-header">
                <MudText Typo="Typo.h5">Produits</MudText>
            </div>
            <div class="tree-view-container">
                @if (ProductFamilies != null)
                {
                    <MudTreeView Items="ProductTreeItems" MultiSelection="true" Hover="true" @bind-SelectedValues="ProductSelectedValues">
                        <ItemTemplate>
                            <MudTreeViewItem @bind-Expanded="@context.IsExpanded" Items="@context.TreeItems" Value="@context" Text="@context.Name"></MudTreeViewItem>
                        </ItemTemplate>
                    </MudTreeView>
                }
            </div>
        </MudItem>

    </MudGrid>



    <MudGrid Class="action-buttons" Justify="Justify.Center" AlignItems="AlignItems.Center">
        <MudItem xs="6">
            <MudButton Color="Color.Error" Variant="MudBlazor.Variant.Filled" FullWidth OnClick="CancelLink">Enlever</MudButton>
     </MudItem>
     <MudItem xs="6">
         <MudButton Color="Color.Success" Variant="MudBlazor.Variant.Filled" FullWidth OnClick="VerifyAsync">Lier</MudButton>
         </MudItem>
     </MudGrid>

}
else
{
    <MudGrid>
        <MudItem xs="6" Class="bordered-paper">
            <div class="tree-title sticky-header">
                <MudText Typo="Typo.h5">Couleurs</MudText>
            </div>
            <div class="tree-view-container">
                @if (Colors != null)
                {
                    <MudTreeView Items="ColorTreeItems" Hover="true" @bind-ActivatedValue="ColorActivatedValue" @bind-SelectedValues="ColorSelectedValues">
                        <ItemTemplate>
                            @if (@context.IsSelected)
                            {
                                <MudTreeViewItem Icon="@Icons.Material.Filled.Label" IconColor="Color.Success" ActivatedChanged="@(()=>ActiveAsync(context,0))" @bind-Expanded="@context.IsExpanded" Items="@context.TreeItems" Value="@context" Text="@context.Name"></MudTreeViewItem>
                            }
                            else
                            {
                                <MudTreeViewItem Icon="@Icons.Material.Filled.Label" ActivatedChanged="@(()=>ActiveAsync(context,0))" @bind-Expanded="@context.IsExpanded" Items="@context.TreeItems" Value="@context" Text="@context.Name"></MudTreeViewItem>
                            }
                            
                        </ItemTemplate>
                    </MudTreeView>
                }
            </div>
        </MudItem>
        <MudItem xs="6" Class="bordered-paper">
            <div class="tree-title sticky-header">
                <MudText Typo="Typo.h5">Produits</MudText>
            </div>
            <div class="tree-view-container">
                @if (ProductFamilies != null)
                {
                    <MudTreeView Items="ProductTreeItems" Hover="true" @bind-ActivatedValue="ProductActivatedValue" @bind-SelectedValues="ProductSelectedValues">
                        <ItemTemplate>
                            @if (@context.IsSelected)
                            {
                                <MudTreeViewItem Icon="@Icons.Material.Filled.Label" IconColor="Color.Success" ActivatedChanged="@(()=>ActiveAsync(context,1))" @bind-Expanded="@context.IsExpanded" Items="@context.TreeItems" Value="@context" Text="@context.Name"></MudTreeViewItem>
                            }
                            else
                            {
                                <MudTreeViewItem Icon="@Icons.Material.Filled.Label" ActivatedChanged="@(()=>ActiveAsync(context,1))" @bind-Expanded="@context.IsExpanded" Items="@context.TreeItems" Value="@context" Text="@context.Name"></MudTreeViewItem>
                            }

                        </ItemTemplate>
                    </MudTreeView>
                }
            </div>
        </MudItem>
    </MudGrid>
}


