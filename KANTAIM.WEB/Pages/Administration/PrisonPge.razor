
@page "/Administration/PrisonPge"
@using KANTAIM.DAL.Model;
@using KANTAIM.WEB.ViewModels;
@* @using System.Net.Http.Json
@inject HttpClient httpClient *@


<style>
    .mud-shrink ~ label.mud-input-label.mud-input-label-inputcontrol, .mud-input:focus-within ~ label.mud-input-label.mud-input-label-inputcontrol {
        transform: translate(0,1.5px) scale(1.0);
    }

    .mud-picker-inline {
        display: flex;
        flex: 1 1 auto;
        position: relative;
        max-width: 350px;
    }

        .mud-picker-inline.mud-picker-input-button .mud-input, .mud-picker-inline.mud-picker-input-button .mud-input .mud-input-root {
            cursor: pointer;
            width: auto;
        }

    .mud-table-container {
        width: 100%;
        overflow-y: clip;
    }

    .custom-disabled-button {
        pointer-events: none;
    }

    .mud-table {
        height: min-content;
        width: 100%;
    }

</style>

<div class="pageTitle">
    <MudText Typo="Typo.h4">Prison Page</MudText>
</div>


@if (Containers != null)
{
    <MudDataGrid Items="@employees" Filterable="false" SortMode="@SortMode.None" Groupable="false">
        <Columns>
            <PropertyColumn Property="x => x.Name" />
            <PropertyColumn Property="x => x.Position" />
            <PropertyColumn Property="x => x.YearsEmployed" Title="Years Employed" />
            <PropertyColumn Property="x => x.Salary" Format="C" />
            <PropertyColumn Property="x => x.Salary * x.YearsEmployed" Title="Total Earned" Format="C" />
            <TemplateColumn >
                <CellTemplate>
                    <MudStack Row>
                        <MudRating  SelectedValue="@context.Item.Rating" />
                        <MudButton Variant="MudBlazor.Variant.Filled" Color="@Color.Primary">Hire</MudButton>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>


    <MudDataGrid Items="@Containers" Dense=true 
                 Virtualize="true" SelectOnRowClick=false MultiSelection=true Bordered=true
                 Filterable="true" SortMode="SortMode.Multiple" Hideable="false" QuickFilter="@_quickFilter">
       
        <Columns>

            <PropertyColumn Property="x => x.container.Number" Title="Contenaire">
                <CellTemplate>
                    @context.Item.container.ContainerType.Name - @context.Item.container.Number
                </CellTemplate>
            </PropertyColumn>

          @*   <PropertyColumn Property="x => x.container.Number" Title="ContenNuméro" /> *@
            <PropertyColumn Property="x => x.container.FillStatus" Title="Remplissage">
                <EditTemplate>
                    <MudSelect T=int @bind-Value="context.Item.container.FillStatus">
                        @foreach (var f in ContainerStatus)
                        {
                            <MudSelectItem Value="@f.Key">@f.Value</MudSelectItem>
                        }
                    </MudSelect>
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.prodTime" Title="Date Produit" />


            <PropertyColumn Property="x => x.stockTime" Title="Date Prison" Format="dd/MM/yyyy HH:mm:ss" />
        
  @*          
            <PropertyColumn Property="x => x.container.ContainerTypeID" Title="Type">
                <EditTemplate>
                    <MudSelect T=int? @bind-Value="context.Item.container.ContainerTypeID">
                        @foreach (var f in context.Item.container.ContainerTypes)
                        {
                            <MudSelectItem T=int? Value="@f.Id">@f.Name</MudSelectItem>
                        }
                    </MudSelect>
                </EditTemplate>
            </PropertyColumn> *@

            <PropertyColumn Property="x => x.container.BigContainer" Title="Conditioné dans">
                <CellTemplate>
                    @context.Item.container.BigContainer.ContainerType.Name
                </CellTemplate>
            </PropertyColumn>

            @* <PropertyColumn Property="x => x.container.ContainerID" Title="Stocké dans">
                <EditTemplate>
                    <MudSelect T=int? @bind-Value=context.Item.container.ContainerID>
                        <MudSelectItem T=int? Value="null">None</MudSelectItem>                           
                        @foreach (var f in context.Item.container.Containers.OrderBy(s => s.Number))
                        {
                            <MudSelectItem T=int? Value="@f.Id">@f.Number</MudSelectItem>
                        }
                    </MudSelect>
                </EditTemplate>
            </PropertyColumn> *@

            <PropertyColumn Property="x => x.container.CellStock.Name" Title="Cellule">
                <CellTemplate>
                    @context.Item.container.CellStock.Name
                </CellTemplate>
            </PropertyColumn>

         @*    <PropertyColumn Property="x => x.container.CellID" Title="Cellule">
                <EditTemplate>
                    <MudSelect T=int? @bind-Value=context.Item.container.CellID>
                        <MudSelectItem T=int? Value="null">None</MudSelectItem>
                        @foreach (var f in context.Item.container.Cells)
                        {
                            <MudSelectItem T=int? Value="@f.Id">@f.Name</MudSelectItem>
                        }
                    </MudSelect>
                </EditTemplate>
            </PropertyColumn> *@


            <TemplateColumn>
                <CellTemplate>
                    <MudStack Row>
                        <MudButton Variant="MudBlazor.Variant.Filled" Color="@Color.Primary">Hire</MudButton>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>

        </Columns>
        <PagerContent>
            <MudDataGridPager T="ContainerWithEvents" PageSizeOptions="@(new int[] {14, 30, 50,100})" />
        </PagerContent>
    </MudDataGrid>
}
else
{
    <MudCard>
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" />
        <MudCardContent>
            <MudSkeleton Width="30%" Height="42px;" />
            <MudSkeleton Width="80%" />
            <MudSkeleton Width="100%" />
        </MudCardContent>
        <MudCardActions>
            <MudSkeleton Width="64px" Height="40px" Class="ml-2" />
            <MudSkeleton Width="105px" Height="40px" Class="ml-3" />
        </MudCardActions>
        <MudProgressLinear Color="Color.Default" Indeterminate="true" Class="my-7" />
    </MudCard>
}