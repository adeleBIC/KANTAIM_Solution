@page "/Consulation/StoragePge"
@using KANTAIM.DAL.Model;
@using KANTAIM.WEB.ViewModels;
<style>
    .bordered-paper {
        border: 1px solid #dee2e6; /* Border color */
        border-radius: 4px; /* Rounded corners */
        overflow: hidden; /* Prevent overflow */
    }

    .tree-view-container {
        padding: 10px; /* Padding inside the tree view */
        /* Add margin to the bottom to prevent overlap with action buttons */
        overflow-y: auto; /* Enable vertical scroll */
        height: 100%;
        display: flex;
    }

    .tree-view-container-edit {
        padding: 10px; /* Padding inside the tree view */
        /* Add margin to the bottom to prevent overlap with action buttons */
        overflow-y: auto; /* Enable vertical scroll */
        height: 100%;
        display: flex;
    }

    .tree-title {
        padding: 10px; /* Padding around title */
        background: #f5f5f5; /* Light grey background for the title */
        border-bottom: 1px solid #dee2e6; /* Border under the title */
    }

    .action-buttons {
        position: fixed;
        bottom: 0;
        width: 100%;
        background: white;
        padding: 10px;
        box-shadow: 0 -2px 5px rgba(0, 0, 0, 0.1);
    }

        .action-buttons .mud-grid-item {
            display: flex;
            justify-content: center; /* Center button horizontally */
            align-items: center; /* Center button vertically */
        }

    .sticky-header {
        position: sticky;
        top: 0;
        background: white;
        z-index: 1000;
    }
</style>

<div class="pageTitle sticky-header">
    <MudText Typo="Typo.h4">Stockage Consultation</MudText>
</div>

<div class="pa-4 content">
    <MudGrid>
        <MudItem xs="6" Class="bordered-paper">
            <div class="tree-title sticky-header">
                <MudText Typo="Typo.h5">Produits</MudText>
            </div>
            <div class="tree-view-container">
                @if (ProductFamilies != null)
                {
                    <MudTreeView Items="ProductTreeItems" Hover="true" SingleSelection="true" @bind-SelectedValue="ProductActivatedValue">
                        <ItemTemplate>
                            <MudTreeViewItem Icon="@Icons.Material.Filled.Label" OnClick="@(() => SelectAsync(context))" @bind-Expanded="@context.IsExpanded" Items="@context.TreeItems" Value="@context" Text="@context.Name"></MudTreeViewItem>
                        </ItemTemplate>
                    </MudTreeView>
                }
            </div>
        </MudItem>

        <MudItem xs="6" Class="bordered-paper">
            <div class="tree-title sticky-header">
                <MudText Typo="Typo.h5">stockage Info</MudText>
            </div>
            <div class="tree-view-container">
                @if (cells != null && cells.Any())
                {
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Cell Name</th>
                                <th>Cell Status</th>
                                <th>Event Time</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in cells)
                            {
                                <tr>
                                    <td>@log.Cell.Name</td>
                                    <td>@CellStatus[log.Cell.Status]</td>
                                    <td>@log.EventTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
            
        </MudItem>
        
    </MudGrid>

</div>
