@page "/Consultation/LogPge"
@using KANTAIM.DAL.Model;
@using KANTAIM.WEB.ViewModels;

<style>
    .wide-column {
        min-width: 180px;
    }
    .date-filter-container {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }
    .date-picker {
        min-width: 180px;
    }
</style>

<div class="pageTitle">
    <MudText Typo="Typo.h4">Historique action Kanban</MudText>
</div>

<!-- Filtre par date -->
<MudPaper Class="p-4 mb-4 d-flex flex-wrap align-items-center gap-4" Elevation="2" Rounded="true" Outlined="true">

   @*  <MudText Typo="Typo.body1">Filtrer par date:</MudText> *@
    <MudDatePicker @bind-Date="startDate" 
                   Label="Date de début" 
                   DateFormat="dd/MM/yyyy"
                   Class="date-picker" />
    <MudDatePicker @bind-Date="endDate" 
                   Label="Date de fin" 
                   DateFormat="dd/MM/yyyy"
                   Class="date-picker" />
    <MudButton Variant="MudBlazor.Variant.Filled" 
               Color="Color.Primary" 
               OnClick="ApplyDateFilter">
        Appliquer
    </MudButton>
    <MudButton Variant="MudBlazor.Variant.Outlined" 
               Color="Color.Primary" 
               OnClick="ResetDateFilter">
        30 derniers jours
    </MudButton>
    <MudButton Variant="MudBlazor.Variant.Text" 
               Color="Color.Primary" 
               OnClick="ClearDateFilter">
        Afficher tout
    </MudButton>
</MudPaper>

@if (isLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-2" />
}
@if (Logs != null)
{
    <MudDataGrid T="LogVM" RowClassFunc="RowClassFct" Items="@Logs" Dense=true Hover=true ReadOnly=true EditMode="MudBlazor.DataGridEditMode.Cell"
                 Virtualize="true" SelectOnRowClick=false MultiSelection=true SelectedItemsChanged="SelectionChanged" Bordered=true
                 Filterable="true" SortMode="SortMode.Multiple" Hideable="false" QuickFilter="@_quickFilter">
@*         <ToolBarContent>
            <MudSpacer />
            <MudTextField @bind-Value="_searchString" 
                         Placeholder="Recherche Container" 
                         Adornment="Adornment.Start" 
                         Immediate="true"
                         AdornmentIcon="@Icons.Material.Filled.Search" 
                         IconSize="Size.Medium" 
                         Class="mt-0" />
        </ToolBarContent> *@

        <Columns>
            <SelectColumn ShowInFooter=false />
            <PropertyColumn Property="x => x.EventTime" Title="Date" Class="wide-column">
                <CellTemplate>
                    <MudTextField @bind-Value="context.Item.EventTime" Format="dd/MM/yyyy HH:mm:ss" />
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Container.Number" Title="Contenaire">
                <CellTemplate>
                    @context.Item.Container.ContainerType.Name - @context.Item.Container.Number
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Operation.ToString()" Title="Action">
                <CellTemplate>
                    @Operations[context.Item.Operation]
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.FillStatus.ToString()" Title="Remplissage">
                <CellTemplate>
                    @ContainerStatus[context.Item.FillStatus]
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Container.Number" Title="Conditioné dans">
                <CellTemplate>
                    @context.Item.Container.Number
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Cell.Name" Title="Cellule">
                <CellTemplate>
                    @context.Item.Cell.Name
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Product.Name" Title="Produit">
                <CellTemplate>
                    @context.Item.Product.Name
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ProdColor.Name" Title="Couleur">
                <CellTemplate>
                    @context.Item.ProdColor.Name
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Press.Number" Title="Presse">
                <CellTemplate>
                    @context.Item.Press.Number
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Shape.Name" Title="Moule">
                <CellTemplate>
                    @context.Item.Shape.Number - @context.Item.Shape.Name
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Machine.Name" Title="Machine">
                <CellTemplate>
                    @context.Item.Machine.Name
                </CellTemplate>
            </PropertyColumn>
            
            <PropertyColumn Property="x => x.Comment" Title="Commentaire" Required=false />
        </Columns>
        <PagerContent>
            <MudDataGridPager T="LogVM" PageSizeOptions="@(new int[] {13, 30, 50,100})" />
        </PagerContent>
    </MudDataGrid>
}
else
{
    <MudCard>
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" />
        <MudCardContent>
            <MudSkeleton Width="30%" Height="42px;" />
            <MudSkeleton Width="80%" />
            <MudSkeleton Width="100%" />
        </MudCardContent>
        <MudCardActions>
            <MudSkeleton Width="64px" Height="40px" Class="ml-2" />
            <MudSkeleton Width="105px" Height="40px" Class="ml-3" />
        </MudCardActions>
        <MudProgressLinear Color="Color.Default" Indeterminate="true" Class="my-7" />
    </MudCard>
}