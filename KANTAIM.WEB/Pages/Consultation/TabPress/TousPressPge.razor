@page "/Consultation/TabPress/TousPressPge"
@using KANTAIM.DAL.Model;
@using KANTAIM.WEB.ViewModels;
@using MudBlazor
@using static MudBlazor.Icons

<style>
    .table-container {
        display: flex;
        justify-content: center;
        align-items: flex-start; /* Align to the top of the container */
        height: 50vh; /* Set the height to one-third of the viewport height */
    }

    table, th, td {
        border: 1px solid black;
    }

    table {
        margin-top: 40px;
        width: 99%;
        height: 90%;
    }

    th, td {
        padding: 0px;
        text-align: center;
    }

    .grey-th {
        background-color: lightgrey;
        font-size: 20px;
        font-family: Calibri;
    }

    .orange-th {
        background-color: darkorange;
        font-size: 20px;
        font-family: Calibri;
    }

    .sizeTd {
        height: 35px;
        font-size: 18px;
    }


    /* Style for correct data */
    .correct {
        background-color: #4CAF50; /* Green */
        color: white;
    }

    /* Style for fault data */
    .fault {
        background-color: #f44336; /* Red */
        color: white;
    }

    .sizeCommentTdColor {
        height: 30px;
        width: 30px;
        font-size: 20px;
        background-color: darkorange;
    }

    .sizeCommentTd {
        height: 30px;
        width: 30px;
        font-size: 20px;
    }

    .tooltip1 {
        position: relative;
        display: inline-block;
        font-size: 20px;
    }

        .tooltip1 .tooltiptext1 {
            visibility: hidden;
            width: 300px;
            background-color: #555;
            color: #fff;
            text-align: center;
            border-radius: 6px;
            padding: 5px 0;
            position: absolute;
            z-index: 1;
            bottom: 125%;
            left: 50%;
            margin-left: -60px;
            opacity: 0;
            transition: opacity 0.3s;
        }

            .tooltip1 .tooltiptext1::after {
                content: "";
                position: absolute;
                top: 100%;
                left: 20%;
                margin-left: -5px;
                border-width: 5px;
                border-style: solid;
                border-color: #555 transparent transparent transparent;
            }

        .tooltip1:hover .tooltiptext1 {
            visibility: visible;
            opacity: 1;
        }
</style>

<MudPaper Height="850px" Style="overflow:hidden; position:relative;">
    <MudDrawerContainer Class="mud-height-full">
        <MudDrawer @bind-Open="@open" Fixed="false" Elevation="1" Variant="@DrawerVariant.Mini" OpenMiniOnHover="true">
            <MudNavMenu>
                <MudNavLink Href="/Consultation/TabPress/JourPge" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Today">Toutes les presses / Jour</MudNavLink>
                <MudNavLink Href="/Consultation/TabPress/SemainePge" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.CalendarViewWeek">Tableau Presses / Semaine</MudNavLink>
                <MudNavLink Href="/Consultation/TabPress/TousPressPge" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.CalendarMonth">Tous les Presses / Semaine</MudNavLink>
            </MudNavMenu>
        </MudDrawer>

        <MudGrid>
            <MudItem xs="12" Style="display: flex; justify-content: center; align-items: flex-start; margin-top: 20px;">
                <div style="display: flex; flex-direction: row; align-items: center;">
                   
                    <MudDatePicker @ref="_picker" Label="Date" @bind-Date="date" Variant="MudBlazor.Variant.Outlined" Style="margin-right: 10px;" Picker="DatePickerType.Week">
                        <PickerActions>
                            <MudButton Class="mr-auto align-self-start" OnClick="@(() => _picker.Clear())">Clear</MudButton>
                            <MudButton OnClick="@(() => _picker.Close(false))">Cancel</MudButton>
                            <MudButton Color="Color.Primary" OnClick="@(() => {_picker.Close(); RefreshData();})">Ok</MudButton>
                        </PickerActions>
                    </MudDatePicker>

                    <MudButton Variant="MudBlazor.Variant.Filled" Color="Color.Primary" OnClick="RefreshData">Afficher</MudButton>

                </div>
            </MudItem>
        </MudGrid>
        @if (daysOfWeekList != null)
        {
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th class="grey-th">Presses / Jour</th>
                            @foreach (string day in daysOfWeekList)
                            {
                                <th colspan="3" class="grey-th">@day</th>
                            }
                            <th colspan="3" class="grey-th">Total</th>
                        </tr>
                    </thead>
                    @if (pressNumber.Count-1 > 0)
                    {
                        int i;
                        <tbody>
                            @for (i = 0; i < Length+1; i++)
                            {
                                int j;
                                <tr>
                                    <th class="orange-th">@pressNumber[i]</th>
                                    @for(j = 0; j < 8; j++)
                                    {
                                        @if(Data[i][j] != null)
                                        {
                                            <td colspan="1" class="sizeTd">
                                                @Data[i][j].Counter.ToString("# ### ### ##0")
                                            </td>
                                            <td colspan="1" class="@((Data[i][j].objOK) ? "correct" : "fault")">@Data[i][j].ValueTRS %</td>
                                            @if (@Data[i][j].comment != null)
                                            {
                                                <td class="sizeCommentTdColor">
                                                    <div class="tooltip1">
                                                        C
                                                        <span class="tooltiptext1">@Data[i][j].comment</span>
                                                    </div>
                                                </td>
                                            }
                                            else
                                            {
                                                <td class="sizeCommentTd">
                                                    <div class="tooltip1">
                                                    </div>
                                                </td>
                                                // Affichage case vide
                                            }
                                        }
                                        else
                                        {
                                            <td colspan="1" class="sizeTd"></td>
                                            <td colspan="1" class="sizeTd"></td>
                                            <td colspan="1" class="sizeTd"></td>
                                        }
                                    }

                                </tr>
                            }
                        </tbody>
                    }
                   
                </table>

            </div>
        }
        


    </MudDrawerContainer>

</MudPaper>




